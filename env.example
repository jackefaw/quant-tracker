# Copy this file to ".env" and fill in your key.

# Required: free key at https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=your_key_here

# Optional: a Postgres URL (free at neon.tech or supabase.com) so revision history
# survives on cloud hosting. Leave unset to use a local SQLite file instead.
# DATABASE_URL=postgresql://user:pass@host/dbname
